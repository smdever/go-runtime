  async function fn3_Weather(ctx) {
    /* Weather - MCP-backed weather evidence node.
       Supports:
       - static mode: configured City/State/Country/Days -> weather_get_forecast -> inject evidence to all actors
       - dynamic mode: scan prior actor responses for structured MCP request -> call matching weather tool -> inject evidence to requesting actor
    */
    var _name = "Weather";
    await emit_process(_name);

    try {
      set_active_node(ctx, _name);
      console.log("Weather: Weather");
      await emit_update(_name);

      const props = node_props(_name) || {};

      function str(value, fallback = "") {
        const s = String(value ?? "").trim();
        return s ? s : fallback;
      }

      function bool_prop(value, fallback = false) {
        if (typeof value === "boolean") return value;
        const s = String(value ?? "").trim().toLowerCase();
        if (!s) return fallback;
        return s === "true" || s === "1" || s === "yes" || s === "y";
      }

      function int_prop(value, fallback = 3) {
        const n = Number.parseInt(String(value ?? ""), 10);
        return Number.isFinite(n) ? n : fallback;
      }

      function clamp(n, min, max) {
        return Math.max(min, Math.min(max, n));
      }

      function actor_name(actor) {
        return actor?.name ?? String(actor ?? "");
      }

      function first_to_actor(utterance) {
        const to = utterance?.to;
        if (Array.isArray(to)) return to[0] ?? null;
        return to ?? null;
      }

      function response_text(response) {
        return String(
          response?.apiResponse?.response ??
          response?.apiResponse?.Response ??
          response?.text ??
          ""
        ).trim();
      }

      function last_response_text(utterance) {
        const responses = utterance?.responses ?? [];
        if (!responses.length) return "";
        return response_text(responses[responses.length - 1]);
      }

      function clone_prior_utterances_into(round, lastRound) {
        round.utterances = [];

        for (const u of (lastRound?.utterances ?? [])) {
          round.utterances.push({
            ...u,
            responses: Array.isArray(u?.responses)
              ? u.responses.map(r => ({ ...r }))
              : [],
          });
        }
      }

      function strip_json_fence(raw) {
        let s = String(raw ?? "").trim();
        if (!s) return "";

        // ```json ... ``` or ``` ... ```
        const fenced = s.match(/^```(?:json)?\s*([\s\S]*?)\s*```$/i);
        if (fenced) return fenced[1].trim();

        // If text surrounds the JSON, try the outermost object.
        const first = s.indexOf("{");
        const last = s.lastIndexOf("}");
        if (first >= 0 && last > first) {
          return s.slice(first, last + 1).trim();
        }

        return s;
      }

      function try_parse_tool_request(raw) {
        const json = strip_json_fence(raw);
        if (!json) return null;

        try {
          const parsed = JSON.parse(json);
          if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) return null;
          if (parsed.toolRequested !== true) return null;
          if (!str(parsed.toolName)) return null;
          return parsed;
        } catch {
          return null;
        }
      }

      function validate_tool_result(result, toolName) {
        if (!result) {
          throw new Error(`MCP tool '${toolName}' returned no result.`);
        }

        const text = String(result?.text ?? "").trim();

        if (result?.isError === true) {
          throw new Error(`MCP tool '${toolName}' reported an error: ${text}`);
        }

        if (!text) {
          throw new Error(`MCP tool '${toolName}' returned no text content.`);
        }
      }

      function format_tool_result_text(result) {
        const text = String(result?.text ?? "").trim();
        if (text) return text;

        try {
          return JSON.stringify(result?.rawResponse ?? result ?? {}, null, 2);
        } catch {
          return String(result ?? "");
        }
      }

      function create_static_weather_prompt(toolResult) {
        const evidence = format_tool_result_text(toolResult);
        return [
          "Weather information has been retrieved from an MCP weather tool.",
          "Use the weather evidence below when answering the user's request.",
          "Do not invent weather details that are not supported by this evidence.",
          "",
          "Weather evidence:",
          evidence,
        ].join("\n");
      }

      function create_dynamic_weather_prompt(request, toolResult) {
        const evidence = format_tool_result_text(toolResult);
        return [
          "You requested weather information from an MCP weather tool.",
          "The requested tool has returned the evidence below.",
          "Use this evidence to answer the user's original request.",
          "Do not invent weather details that are not supported by this evidence.",
          "",
          "Tool request:",
          JSON.stringify(request ?? {}, null, 2),
          "",
          "Weather evidence:",
          evidence,
        ].join("\n");
      }

      const dynamicMode = bool_prop(props.DynamicMode ?? props.dynamicMode, false);
      const injectMode = bool_prop(props.InjectMode ?? props.injectMode, true);

      const endpoint = str(
        props.McpEndpoint ?? props.mcpEndpoint ?? props.Endpoint ?? props.endpoint,
        "http://localhost:3001/mcp"
      );

      const toolName = str(
        props.ToolName ?? props.toolName,
        "weather_get_forecast"
      );

      const lastRound = get_last_round(ctx);
      const round = lastRound
        ? create_round_from_last(ctx, _name, lastRound)
        : create_round(ctx, _name, null);

      clone_prior_utterances_into(round, lastRound);

      const parallel = !!(ctx?.exec?.parallelMode ?? true);
      const tasks = [];

      async function send_prompt_to_actor(actor, prompt, stage) {
        const utt = create_utterance(ctx, round, {
          to: actor,
          from: get_narrator(ctx),
          prompt,
          context: get_last_useful_context(ctx, actor),
        });

        await emit_exec_llm_call(_name, {
          to: actor_name(actor),
          stage,
          promptPreview: String(prompt ?? "").slice(0, 200),
          promptChars: String(prompt ?? "").length,
        });

        const p = (async () => {
          const r = await send_utterance(ctx, utt);
          const rawText = response_text(r);
          await emit_exec_llm_result(_name, {
            from: r?.from?.name,
            stage,
            preview: rawText.slice(0, 200),
            respChars: rawText.length,
          });
          return r;
        })();

        tasks.push(p);
        if (!parallel) await p;
      }

      if (!dynamicMode) {
        const city = str(props.City ?? props.city);
        const state = str(props.State ?? props.state);
        const country = str(props.Country ?? props.country);
        const days = clamp(int_prop(props.Days ?? props.days, 3), 1, 7);

        if (!city) {
          throw new Error(`${_name} requires City in static mode.`);
        }

        const args = { city, state, country, days };

        await emit_update(_name, {
          phase: "mcp.tool.call",
          mode: "static",
          endpoint,
          toolName,
          args,
        });

        const toolResult = await call_mcp_tool(endpoint, toolName, args);
        validate_tool_result(toolResult, toolName);

        ctx.vars ||= {};
        ctx.vars[_name + ".toolResult"] = toolResult;
        ctx.vars[_name + ".text"] = format_tool_result_text(toolResult);

        await emit_update(_name, {
          phase: "mcp.tool.result",
          mode: "static",
          endpoint,
          toolName,
          isError: toolResult?.isError === true,
          textPreview: format_tool_result_text(toolResult).slice(0, 200),
        });

        const prompt = create_static_weather_prompt(toolResult);
        const actors = get_actors(ctx) || [];

        for (const actor of actors) {
          await send_prompt_to_actor(actor, prompt, "weather_static_injection");
        }
      } else {
        let matchingRequests = 0;
        let injectedResponses = 0;

        for (const priorUtterance of (lastRound?.utterances ?? [])) {
          const raw = last_response_text(priorUtterance);
          const request = try_parse_tool_request(raw);

          if (!request) continue;

          const requestedToolName = str(request.toolName);
          if (requestedToolName.toLowerCase() !== toolName.toLowerCase()) {
            console.log(`${_name} ignored MCP request for '${requestedToolName}' because this node handles '${toolName}'.`);
            continue;
          }

          matchingRequests++;

          const args = (request.arguments && typeof request.arguments === "object" && !Array.isArray(request.arguments))
            ? request.arguments
            : {};

          await emit_update(_name, {
            phase: "mcp.tool.call",
            mode: "dynamic",
            endpoint,
            toolName: requestedToolName,
            args,
          });

          const toolResult = await call_mcp_tool(endpoint, requestedToolName, args);
          validate_tool_result(toolResult, requestedToolName);

          ctx.vars ||= {};
          ctx.vars[_name + ".lastToolResult"] = toolResult;
          ctx.vars[_name + ".lastText"] = format_tool_result_text(toolResult);

          await emit_update(_name, {
            phase: "mcp.tool.result",
            mode: "dynamic",
            endpoint,
            toolName: requestedToolName,
            isError: toolResult?.isError === true,
            textPreview: format_tool_result_text(toolResult).slice(0, 200),
          });

          if (!injectMode) continue;

          const actor = first_to_actor(priorUtterance);
          if (!actor) continue;

          const prompt = create_dynamic_weather_prompt(request, toolResult);
          await send_prompt_to_actor(actor, prompt, "weather_dynamic_injection");
          injectedResponses++;
        }

        await emit_update(_name, {
          mode: "dynamic",
          matchingRequests,
          injectedResponses,
          injectMode,
        });
      }

      if (parallel) await Promise.allSettled(tasks);

      await emit_update(_name);
      await emit_ready(_name);

      await fn4_Deliver(ctx);
    } catch (ex) {
      console.error(`Error in ${_name}:`, ex);
      throw ex;
    } finally {
    }
    return;
  }

  async function fn4_Deliver(ctx) {
    /* Deliver - emits the final unifiedResponse from the most recent useful utterance response. */
    var _name = "Deliver";
    await emit_process(_name);
    try {
      // capture the previous node identity before we overwrite activeNode
      const _prevNode = ctx.activeNode ?? (ctx.conversation?.activeNode ?? null);

      set_active_node(ctx, _name);
      console.log("Deliver: Deliver");

      const lastRound = get_last_round(ctx);

      // Optional: mirror C# behavior by creating a boundary round for Deliver
      // (Whether you want this is up to you; it's mostly audit/logging.)
      create_round(ctx, _name, lastRound);

      const singlePara = !!(node_props(_name)?.useSingleParagraphResponse);

      const lastWasUnified =
          (lastRound?.name === "UnifiedResponse")
       || (_prevNode === "UnifiedResponse");

      function single_paragraph(s) {
        return String(s ?? "")
          .replace(/\s*\n+\s*/g, " ")
          .replace(/\s{2,}/g, " ")
          .trim();
      }

      function last_useful_text(preferActorName = null) {
        const rounds = (ctx.conversation?.rounds ?? []);
        for (let ri = rounds.length - 1; ri >= 0; ri--) {
          const rr = rounds[ri];
          const utterances = rr?.utterances ?? [];
          for (let ui = utterances.length - 1; ui >= 0; ui--) {
            const u = utterances[ui];

            if (preferActorName) {
              const toName = u?.to?.name ?? String(u?.to ?? "");
              if (toName && toName !== preferActorName) continue;
            }

            const responses = u?.responses ?? [];
            for (let pi = responses.length - 1; pi >= 0; pi--) {
              const r = responses[pi];
              const raw = String(r?.apiResponse?.response ?? r?.apiResponse?.Response ?? r?.text ?? "");
              const t = raw.trim();
              if (t) return t;
            }
          }
        }
        return "";
      }

      const firstActorName = (get_actors(ctx)?.[0]?.name ?? null);

      // C# difference: lastWasUnified uses a different lane; in LOKIT-Lite we can just broaden scan
      const reasoningName = ctx.reasoning?.name ?? null;

      let response = "";
      if (lastWasUnified) {
        // C# behavior: UnifiedResponse pulls from Reasoning actor
        response = (reasoningName ? last_useful_text(reasoningName) : "")
               || last_useful_text(null);
      } else {
        // C# behavior: non-unified pulls from first actor
        response = (firstActorName ? last_useful_text(firstActorName) : "")
               || last_useful_text(null);
      }

      const unified = singlePara ? single_paragraph(response) : String(response ?? "");

      ctx.vars ||= {};
      ctx.vars.unifiedResponse = unified;

      ctx.conversation ||= {};
      ctx.conversation.unifiedResponse = unified;

      console.log(unified);

      // Emit delivered output into the outer log (FULL text)
      const full = String(unified ?? "");
      await emit_exec_llm_result(_name, {
        from: "Deliver",
        preview: full,
        respChars: full.length
      });

      await emit_update(_name, { unifiedChars: unified.length, singlePara, lastWasUnified });
      await emit_ready(_name);

      await fn5_End(ctx);
    } finally {
    }
    return;
  }

  async function fn5_End(ctx) {
    /* End - Terminal for LLM completion of flow. */
    var _name = "End";
    console.log("End: End");
    await emit_process(_name);

    try {
      set_active_node(ctx, _name);
      await emit_update(_name);

      const lastRound = get_last_round(ctx);
      create_round(ctx, _name, lastRound);

      // Mirrors C#:
      // foreach (INode node in Conversation.ProcessNodes) node.Reset();
      // In compiled JS, node-local reset behavior is represented by ctx.nodeState.
      // Keep this conservative: clear nodeState only if present.
      if (ctx?.nodeState && typeof ctx.nodeState === "object") {
        ctx.nodeState = {};
      }

      const b = node_blurbs(_name) || {};
      const complete = String(b?.Complete ?? b?.complete ?? "");
      if (complete) console.log(complete);

      await emit_update(_name);
      await emit_ready(_name);
    } finally {
    }
    return ctx;
  }

  return { info, getInformation, getRuntime, execute, continue: cont };
}
